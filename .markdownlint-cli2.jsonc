// markdownlint-cli2 runner config.
// Globs cover the top-level fork docs governed by STYLE.md.
// docs/tutorials/ is linted as of sub-project 12.D.
{
  "config": ".markdownlint.jsonc",
  "globs": [
    "STYLE.md",
    "README.md",
    "CONTRIBUTING.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "docs/tutorials/*.md"
  ],
  "ignores": [
    "node_modules/**",
    "dist/**",
    "docs/superpowers/**"
  ]
}
