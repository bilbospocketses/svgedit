{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src/embed",
    "outDir": "dist/embed",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "module": "ES2022",
    "moduleResolution": "Bundler"
  },
  "include": ["src/embed/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.test.js"]
}
