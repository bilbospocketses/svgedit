{
  "name": "svgedit",
  "version": "7.4.1",
  "description": "Powerful SVG-Editor for your browser ",
  "main": "dist/editor/Editor.js",
  "module": "dist/editor/Editor.js",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/svgcanvas"
  ],
  "scripts": {
    "lint": "eslint . && markdownlint-cli2 && npm run lint:hex",
    "lint:hex": "node scripts/check-no-raw-hex.mjs --error",
    "lint:md": "markdownlint-cli2",
    "pretest": "npm run lint",
    "test": "vitest run --coverage && tsx scripts/run-e2e.ts",
    "typecheck": "tsc --build packages/svgcanvas",
    "typecheck:editor": "tsc --build packages/svgcanvas && tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "build:embed": "tsc --project tsconfig.embed.json",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "build": "npm run typecheck && vite build packages/svgcanvas && vite build && npm run build:embed && npm run build:server",
    "postbuild": "tsx scripts/copy-static.ts && tsx scripts/build-extensions.ts",
    "start": "vite dev --host",
    "prestart": "echo svgedit is available at http://localhost:8100/src/editor/index.html",
    "serve": "npm run build && node dist/server/index.js",
    "start:e2e": "vite preview --host --port 9000 --strictPort --outDir dist/editor",
    "build:launcher": "cargo build --release --manifest-path launcher/Cargo.toml --config launcher/.cargo/config.toml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bilbospocketses/svgedit.git"
  },
  "keywords": [
    "svg-editor",
    "javascript",
    "svg-edit",
    "svg"
  ],
  "author": "Jamie Chapman <jamie@boxtechs.com>",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/bilbospocketses/svgedit/issues"
  },
  "homepage": "https://github.com/bilbospocketses/svgedit#readme",
  "browserslist": [
    "defaults",
    "not IE 11",
    "not OperaMini all"
  ],
  "exports": {
    ".": "./dist/editor/Editor.js",
    "./embed": {
      "import": "./dist/embed/index.js",
      "types": "./dist/embed/index.d.ts"
    }
  },
  "dependencies": {
    "@svgedit/svgcanvas": "7.4.1",
    "browser-fs-access": "0.38.0",
    "dompurify": "^3.4.0",
    "jspdf": "4.2.1",
    "lit": "^3.3.3",
    "sirv": "^3.0.2",
    "svg2pdf.js": "2.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-dynamic-import-vars": "2.1.5",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^10.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "globals": "^15.15.0",
    "jsdom": "^27.4.0",
    "markdownlint-cli2": "^0.22.1",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.3.5",
    "vite-plugin-string": "^1.2.3",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.2"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0",
    "glob": "^10.5.0",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "ws": "^8.21.0"
  }
}
