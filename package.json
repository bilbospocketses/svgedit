{
  "name": "svgedit",
  "version": "7.4.1",
  "description": "Powerful SVG-Editor for your browser ",
  "main": "dist/editor/Editor.js",
  "module": "dist/editor/Editor.js",
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/svgcanvas"
  ],
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vitest run --coverage && node scripts/run-e2e.mjs",
    "build": "vite build packages/svgcanvas && vite build",
    "postbuild": "node scripts/copy-static.mjs && node scripts/build-extensions.mjs",
    "start": "vite dev --host --port 8000 --strictPort",
    "prestart": "echo svgedit is available at http://localhost:8000/src/editor/index.html",
    "start:iife": "npm run build && vite preview --host --port 8000 --strictPort --outDir dist/editor --open /iife-index.html",
    "start:e2e": "vite preview --host --port 8000 --strictPort --outDir dist/editor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bilbospocketses/svgedit.git"
  },
  "keywords": [
    "svg-editor",
    "javascript",
    "svg-edit",
    "svg"
  ],
  "author": "Jamie Chapman <jamie@boxtechs.com>",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/bilbospocketses/svgedit/issues"
  },
  "homepage": "https://github.com/bilbospocketses/svgedit#readme",
  "browserslist": [
    "defaults",
    "not IE 11",
    "not OperaMini all"
  ],
  "dependencies": {
    "@svgedit/svgcanvas": "7.4.1",
    "browser-fs-access": "0.38.0",
    "elix": "15.0.1",
    "jspdf": "4.2.1",
    "path-data-polyfill": "^1.0.10",
    "svg2pdf.js": "2.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-dynamic-import-vars": "2.1.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jamilih": "0.63.1",
    "jsdom": "^27.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.2",
    "vite-plugin-string": "^1.2.3",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.55.1"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "flatted": "^3.4.2",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0",
    "glob": "^10.5.0"
  }
}
